# Single source of truth for which vendored toolchain version is
# active. Loaded by justfile via `set dotenv-load`, sourced by
# scripts/vendor-fetch.sh. Bumping a tool is one line here plus
# a new versioned subdirectory under vendor/<tool>/.

SW_EM24_VERSION=v0.1.0

# Optional binary overrides. When set, vendor-fetch.sh copies from
# the pointed-at path instead of resolving the upstream sibling +
# cargo target/release. Useful on dev systems that don't follow the
# sibling-repos layout documented in vendor/sw-em24/*/version.json.
# Example:
#   SW_EM24_BIN=/disk1/github/softwarewrighter/devgroup/work/bin/cor24-run
